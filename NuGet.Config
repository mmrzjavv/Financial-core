<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <add key="devneeds" value="https://nuget.devneeds.ir/v3/index.json" />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>

  <packageSourceMapping>
    <packageSource key="devneeds">
      <package pattern="Microsoft.EntityFrameworkCore*" />
    </packageSource>

    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
